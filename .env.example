# iBudget Environment Configuration
#
# For local-only development (no Supabase needed):
#   EXPO_PUBLIC_AUTH_PROVIDER=local npm run web
#
# For production/Supabase mode:
#   npm run web

# Auth provider: "local" for offline dev, omit for Supabase
# EXPO_PUBLIC_AUTH_PROVIDER=local

# Supabase (required for production)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# PowerSync (required for sync)
EXPO_PUBLIC_POWERSYNC_URL=https://your-instance.powersync.journeyapps.com

# Set to "true" to allow public sign-up (omit or "false" for invite-only beta)
# EXPO_PUBLIC_ALLOW_SIGNUP=true
